{
  "name": "sentinel",
  "version": "0.1.3",
  "description": "AI-powered contextual security auditing platform — red-team-grade SAST that thinks like an attacker.",
  "author": "Wembie",
  "license": "MIT",
  "repo": "https://github.com/Wembie/Sentinel",
  "capabilities": [
    "mcp",
    "skills"
  ],
  "mcp": {
    "command": "uv",
    "args": [
      "run",
      "--project",
      "~/.sentinel",
      "python",
      "-m",
      "sentinel.mcp"
    ],
    "transport": "stdio"
  },
  "skills": "skills/",
  "hooks": "hooks/",
  "tools": [
    "sentinel_audit",
    "sentinel_surface",
    "sentinel_trace",
    "sentinel_attack_graph",
    "sentinel_logic",
    "sentinel_review",
    "sentinel_verify",
    "sentinel_diff",
    "sentinel_harden",
    "sentinel_exploit_chain",
    "sentinel_hunt",
    "sentinel_rules",
    "sentinel_report"
  ]
}
