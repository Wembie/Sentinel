# LLM provider: claude | openai | none
SENTINEL_LLM_PROVIDER=claude
SENTINEL_LLM_MODEL=claude-sonnet-4-6
SENTINEL_LLM_API_KEY=your-api-key-here
SENTINEL_LLM_MAX_TOKENS=8192

# Graph backend: networkx | neo4j
SENTINEL_GRAPH_BACKEND=networkx

# Neo4j (only needed when SENTINEL_GRAPH_BACKEND=neo4j)
SENTINEL_GRAPH_NEO4J_URI=bolt://localhost:7687
SENTINEL_GRAPH_NEO4J_USER=neo4j
SENTINEL_GRAPH_NEO4J_PASSWORD=

# API server
SENTINEL_SERVER_HOST=0.0.0.0
SENTINEL_SERVER_PORT=8000

# Audit limits
SENTINEL_MAX_FILE_SIZE_KB=512
SENTINEL_MAX_FILES_PER_AUDIT=1000

# Debug
SENTINEL_DEBUG=false
SENTINEL_LOG_LEVEL=INFO
